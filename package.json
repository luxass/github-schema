{
  "name": "github-schema",
  "version": "1.22.15",
  "description": "GitHub's GraphQL schema",
  "keywords": [
    "github",
    "github graphql",
    "github schema",
    "graphql"
  ],
  "homepage": "https://github.com/luxass/github-schema",
  "bugs": {
    "url": "https://github.com/luxass/github-schema/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Lucas Nørgård",
    "email": "lucasnrgaard@gmail.com",
    "url": "https://luxass.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luxass/github-schema.git"
  },
  "files": [
    "dist",
    "github-schema.d.ts",
    "github-schema.graphql"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./github-schema": {
      "import": "./dist/github-schema.mjs",
      "require": "./dist/github-schema.cjs"
    },
    "./raw": {
      "import": "./dist/raw.mjs",
      "require": "./dist/raw.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "schema:download": "node --env-file=.env ./scripts/download.ts",
    "schema:codegen": "graphql-codegen",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "graphql": "catalog:graphql",
    "graphql-tag": "catalog:graphql"
  },
  "devDependencies": {
    "@graphql-codegen/add": "catalog:graphql",
    "@graphql-codegen/cli": "catalog:graphql",
    "@graphql-codegen/typescript": "catalog:graphql",
    "@types/node": "catalog:types",
    "oxfmt": "catalog:dev",
    "oxlint": "catalog:dev",
    "oxlint-tsgolint": "catalog:dev",
    "publint": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0"
}
